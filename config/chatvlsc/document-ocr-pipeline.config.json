{
  "$schema": "./schemas/document-ocr-pipeline.config.schema.json",
  "name": "ChatVLSC Document OCR Pipeline",
  "status": "remote_integrity_migration_applied_ingestion_disabled",
  "repository": {
    "provider": "github",
    "repository_full_name": "The-VLSC/brain-slushie",
    "repository_url": "https://github.com/The-VLSC/brain-slushie",
    "default_branch": "main",
    "visibility": "public",
    "publish_policy": "sanitized_config_only",
    "legacy_repository_policy": "Do not include or reintroduce legacy repository references."
  },
  "stageOne": {
    "description": "Initial OCR intake from already-scanned PDF files using scanner-native OCR text and connector extraction where available.",
    "sourceTypes": [
      "connector_object_manifest",
      "onedrive_pdf_manifest",
      "sharepoint_pdf_manifest",
      "uploaded_pdf_manifest"
    ],
    "outputs": [
      "D1 table ocr_documents",
      "D1 table ocr_pages",
      "D1 table ocr_fields",
      "Notion review/database export when connector execution is approved"
    ],
    "reviewFlags": [
      "needs_manual_review",
      "needs_adobe_ocr",
      "needs_rescan",
      "low_confidence_fields"
    ]
  },
  "stageTwo": {
    "description": "Adobe Acrobat OCR only for documents flagged by Stage One.",
    "status": "review_required_before_execution"
  },
  "stageThree": {
    "description": "ChatGPT/OpenAI review for limited matching line items after Stage One and Stage Two outputs exist.",
    "status": "server_side_binding_configured_runtime_verification_required",
    "batchLimit": 10,
    "openaiApiKey": {
      "required": true,
      "status": "secrets_store_binding_configured",
      "binding": "OPENAI_API_KEY",
      "safeSetup": "Use the OpenAI Developers secure key-creation flow when exposed. Do not store plaintext keys in source, Notion, or chat."
    }
  },
  "cloudflare": {
    "worker": "vlsc-user-role-mcp",
    "d1": {
      "binding": "OCR_DB",
      "database_name": "chatvlsc-ocr-stage-one",
      "database_id": "06ce7692-f710-46a2-9a5f-d5428f941e5c",
      "migrations_dir": "migrations",
      "migrations": [
        "migrations/0001_chatvlsc_ocr_stage_one.sql",
        "migrations/0002_ocr_privacy_integrity.sql"
      ],
      "remoteMigrationStatus": "applied_and_verified_2026_07_13",
      "remoteApplicationRowCountsAfterVerification": {
        "ocr_documents": 0,
        "ocr_pages": 0,
        "ocr_fields": 0,
        "ocr_review_events": 0
      }
    },
    "publicEndpoints": {
      "status": "GET /ocr/status",
      "schema": "GET /ocr/schema"
    }
  },
  "privateStorage": {
    "status": "not_enabled",
    "sourceDocumentsStored": false,
    "requiredBeforeIngestion": [
      "approved retention period",
      "container ownership and access scope",
      "private object storage binding",
      "jurisdiction decision",
      "owner sign-off"
    ]
  },
  "notion": {
    "controlSurface": "ChatVLSC App Setup Progress Log",
    "stageOneDatabaseName": "Stage One",
    "policy": "Use Notion for review status and handoff notes. Do not store API keys, refresh tokens, passwords, client secrets, or recovery codes."
  },
  "guards": {
    "noDelete": true,
    "noMove": true,
    "noPublicSensitiveConfig": true,
    "requiresOwnerApprovalBeforeConnectorWrites": true,
    "requiresVerifiedServerSideOpenAiBindingBeforeStageThree": true,
    "ingestionEnabled": false,
    "sourceContentPublic": false
  }
}
