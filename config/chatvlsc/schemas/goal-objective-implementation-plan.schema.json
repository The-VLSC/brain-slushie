{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp.thevlsc.com/schemas/goal-objective-implementation-plan.schema.json",
  "title": "ChatVLSC Goal Objective Implementation Plan",
  "type": "object",
  "required": [
    "name",
    "generated_at",
    "status",
    "completed",
    "remaining_gates",
    "safety"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "minLength": 1 },
    "completed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability", "evidence"],
        "properties": {
          "capability": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "remaining_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability", "gate"],
        "properties": {
          "capability": { "type": "string", "minLength": 1 },
          "gate": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "safety": {
      "type": "object",
      "required": [
        "no_credentials_in_source",
        "no_source_document_ingestion",
        "no_file_move_delete_or_rename",
        "access_fail_closed",
        "payment_execution_enabled"
      ],
      "properties": {
        "no_credentials_in_source": { "const": true },
        "no_source_document_ingestion": { "const": true },
        "no_file_move_delete_or_rename": { "const": true },
        "access_fail_closed": { "const": true },
        "payment_execution_enabled": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
